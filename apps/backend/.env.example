# Example environment variables for the Resolver server
# Copy this file to `.env` and fill real values before running the app

# Server port
PORT=5173

# --- Demo login (create user once: npm run seed:demo) ---
# Email:    demo@resolver.local
# Password: ResolverDemo1!

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/resolver

# JWT secret used to sign tokens
JWT_SECRET=your_jwt_secret_here

# Node environment (development|production)
NODE_ENV=development

# Groq API key for AI service
GROQ_API_KEY=your_groq_api_key_here

# Public URL of the manage UI (same Vercel app users open for /login). No trailing slash.
# Used for invite share links: {MANAGE_URL}/join?id=RES-XXXX
# MANAGE_URL=https://risolver-resolver-manage-system.vercel.app

# Optional: comma-separated origins if you use custom domains (not *.vercel.app)
# CORS_EXTRA_ORIGINS=https://www.example.com,https://manage.example.com
