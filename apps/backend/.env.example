# Example environment variables for the Resolver server
# Copy this file to `.env` and fill real values before running the app

# Server port
PORT=3000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/resolver

# JWT secret used to sign tokens
JWT_SECRET=your_jwt_secret_here

# Node environment (development|production)
NODE_ENV=development

# Groq API key for AI service
GROQ_API_KEY=your_groq_api_key_here

# Optional: other secrets/settings
# SENTRY_DSN=your_sentry_dsn
# REDIS_URL=redis://localhost:6379
